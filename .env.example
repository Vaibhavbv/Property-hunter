# ---------------------------------------------------------------------------
# Supabase — create a project at https://supabase.com and copy these from
# Project Settings → API. The service-role key is SECRET and used only on the
# server (ingestion). Never expose it to the browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Apify — get a token at https://console.apify.com/account/integrations
# The $5/month free tier is enough if MAX_ITEMS_PER_SOURCE stays small.
# ---------------------------------------------------------------------------
APIFY_TOKEN=your-apify-token

# ---------------------------------------------------------------------------
# Cron protection — a random string. The daily scrape endpoint rejects any
# request whose Authorization header is not "Bearer $CRON_SECRET".
# Generate one with: openssl rand -hex 32
# ---------------------------------------------------------------------------
CRON_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Ingestion tuning (optional — sensible defaults live in src/config/sources.ts).
# Lower MAX_ITEMS_PER_SOURCE to spend less Apify credit.
# ---------------------------------------------------------------------------
MAX_ITEMS_PER_SOURCE=25

# Set to "1" to use bundled fixture data instead of calling Apify (no credit
# spent). Great for local development and first-run verification.
USE_FIXTURES=0
